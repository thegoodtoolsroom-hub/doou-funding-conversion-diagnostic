  <assessments>
    <rows>
      <row>
        <id>1</id>
        <sid>427665</sid>
        <scope>T</scope>
        <name>Major conversion barrier</name>
        <minimum>0</minimum>
        <maximum>249</maximum>
        <message>&lt;h2&gt;Major conversion barrier pattern&lt;/h2&gt;&lt;p&gt;Your answers point to several barriers that could stop or slow funding conversion. Use the report to identify the strongest repair sequence before investing more effort in applications.&lt;/p&gt;</message>
        <language>en</language>
      </row>
      <row>
        <id>2</id>
        <sid>427665</sid>
        <scope>T</scope>
        <name>Conversion risk</name>
        <minimum>250</minimum>
        <maximum>392</maximum>
        <message>&lt;h2&gt;Conversion risk pattern&lt;/h2&gt;&lt;p&gt;Your organisation has usable strengths, but some barrier zones are fragile. Prioritise the weakest route, proof, trust, or systems gaps before scaling proposal volume.&lt;/p&gt;</message>
        <language>en</language>
      </row>
      <row>
        <id>3</id>
        <sid>427665</sid>
        <scope>T</scope>
        <name>Light friction</name>
        <minimum>393</minimum>
        <maximum>535</maximum>
        <message>&lt;h2&gt;Light friction pattern&lt;/h2&gt;&lt;p&gt;Your funding conversion foundations are mostly functional. The highest-value improvements are likely in targeting discipline, evidence packaging, relationship route, or document confidence.&lt;/p&gt;</message>
        <language>en</language>
      </row>
      <row>
        <id>4</id>
        <sid>427665</sid>
        <scope>T</scope>
        <name>Strong conversion foundation</name>
        <minimum>536</minimum>
        <maximum>714</maximum>
        <message>&lt;h2&gt;Strong conversion foundation&lt;/h2&gt;&lt;p&gt;Your answers show strong fundability signals. The next step is to use your strongest assets intentionally, protect sensitive evidence, and focus on the routes most likely to convert.&lt;/p&gt;</message>
        <language>en</language>
      </row>
    </rows>
  </assessments>
