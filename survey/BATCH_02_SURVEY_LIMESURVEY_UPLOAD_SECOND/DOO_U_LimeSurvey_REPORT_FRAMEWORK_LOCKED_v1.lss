      </row>
      <row>
        <id>422</id>
        <qid>5250</qid>
        <question>Cold open call</question>
        <help />
        <script />
        <language>en</language>
      </row>
      <row>
        <id>423</id>
        <qid>5251</qid>
        <question>Proactive concept note or unsolicited approach</question>
        <help />
        <script />
        <language>en</language>
      </row>
      <row>
        <id>424</id>
        <qid>5252</qid>
        <question>Intermediary or regrantor route</question>
        <help />
        <script />
        <language>en</language>
      </row>
      <row>
