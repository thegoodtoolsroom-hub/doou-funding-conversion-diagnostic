  <question_l10ns>
    <fields>
      <fieldname>id</fieldname>
      <fieldname>qid</fieldname>
      <fieldname>question</fieldname>
      <fieldname>help</fieldname>
      <fieldname>script</fieldname>
      <fieldname>language</fieldname>
    </fields>
    <rows>
      <row>
        <id>1</id>
        <qid>225</qid>
        <question>What organisation name should appear in the diagnostic report?</question>
        <help>&lt;p&gt;&lt;strong&gt;Help:&lt;/strong&gt; Use the name you want reflected in the diagnostic report. If your legal name and public name differ, add that in the next question.&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Example:&lt;/strong&gt; Use the safest accurate answer. If exact details create risk, use an approximate answer or choose Not applicable / Unsafe to answer.&lt;/p&gt;</help>
        <script />
        <language>en</language>
      </row>
      <row>
        <id>2</id>
        <qid>226</qid>
        <question>Is there a public, trading, movement, or community-facing name that funders may recognise?</question>
        <help>&lt;p&gt;&lt;strong&gt;Help:&lt;/strong&gt; This helps funders connect the legal, public, community, movement or programme name safely.&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Example:&lt;/strong&gt; Choose the option that best explains whether the public name matches the legal name, differs from it, or should remain private for safety.&lt;/p&gt;</help>
        <script />
        <language>en</language>
      </row>
      <row>
        <id>5</id>
        <qid>229</qid>
        <question>Where is the organisation registered or mainly based?</question>
        <help>&lt;p&gt;&lt;strong&gt;Help:&lt;/strong&gt; Funders often check whether your legal base, operating base, and grant route match their eligibility rules. Choose the safest accurate option.&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Example:&lt;/strong&gt; Use the safest accurate answer. If exact details create risk, use an approximate answer or choose Not applicable / Unsafe to answer.&lt;/p&gt;</help>
        <script />
        <language>en</language>
      </row>
      <row>
        <id>6</id>
        <qid>230</qid>
        <question>Where does the work mostly happen?</question>
        <help>&lt;p&gt;&lt;strong&gt;Help:&lt;/strong&gt; Geography affects eligibility, context risk and funder fit. Choose the safest accurate level of detail.&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Example:&lt;/strong&gt; If exact locations could create risk, choose the broadest option that still helps the diagnostic.&lt;/p&gt;</help>
        <script />
        <language>en</language>
      </row>
      <row>
        <id>7</id>
        <qid>231</qid>
        <question>What is the organisation’s primary operating setting?</question>
        <help>&lt;p&gt;&lt;strong&gt;Help:&lt;/strong&gt; This helps the report interpret access, delivery, safety, and context realities. Select all settings that describe where or how the work happens.&lt;/p&gt;&lt;p&gt;&lt;strong&gt;Example:&lt;/strong&gt; Use the safest accurate answer. If exact details create risk, use an approximate answer or choose Not applicable / Unsafe to answer.&lt;/p&gt;</help>
        <script />
        <language>en</language>
      </row>
      <row>
        <id>8</id>
        <qid>5000</qid>
        <question>Border area</question>
        <help />
        <script />
        <language>en</language>
      </row>
      <row>
        <id>9</id>
        <qid>5001</qid>
        <question>Capital city</question>
        <help />
        <script />
